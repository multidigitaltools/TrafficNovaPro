<Application x:Class="TrafficNova.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:conv="clr-namespace:TrafficNova.Converters"
             ShutdownMode="OnLastWindowClose">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- HandyControl 3.x skin + theme -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>

                <!-- App-specific resources -->
                <ResourceDictionary Source="Resources/Colors.xaml" />
                <ResourceDictionary Source="Resources/Fonts.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />

            </ResourceDictionary.MergedDictionaries>

            <!-- Campaign converters (static singletons) -->
            <conv:StatusToBackgroundConverter  x:Key="StatusToBackgroundConverter"/>
            <conv:StatusToForegroundConverter  x:Key="StatusToForegroundConverter"/>
            <conv:JsonToUrlCountConverter      x:Key="JsonToUrlCountConverter"/>
            <conv:ZeroToVisibleConverter       x:Key="ZeroToVisibleConverter"/>
            <conv:NonZeroToVisibleConverter         x:Key="NonZeroToVisibleConverter"/>
            <conv:StringNonEmptyToVisibleConverter  x:Key="StringNonEmptyToVisibleConverter"/>
            <conv:BoolToResultConverter        x:Key="BoolToResultConverter"/>
            <conv:BoolToResultColorConverter   x:Key="BoolToResultColorConverter"/>
            <BooleanToVisibilityConverter       x:Key="BoolToVisibleConverter"/>
            <conv:PauseButtonTextConverter       x:Key="PauseButtonTextConverter"/>
            <conv:PageIndexConverter             x:Key="PageIndexConverter"/>
            <conv:MaxRunsConverter               x:Key="MaxRunsConverter"/>
            <conv:CampaignIdToNameConverter      x:Key="CampaignIdToNameConverter"/>
            <conv:ProgressPercentConverter       x:Key="ProgressPercentConverter"/>
            <conv:ProgressTextConverter          x:Key="ProgressTextConverter"/>
            <conv:NotNullToBoolConverter         x:Key="NotNullToBoolConverter"/>
            <conv:InverseBoolConverter           x:Key="InverseBoolConverter"/>

        </ResourceDictionary>
    </Application.Resources>

</Application>
