<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Primary Palette ===== -->
    <Color x:Key="SidebarColor">#1B2B4B</Color>
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryHoverColor">#1D4ED8</Color>
    <Color x:Key="PrimaryPressedColor">#1E40AF</Color>
    <Color x:Key="BackgroundColor">#EEF2F7</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="TextColor">#0F172A</Color>
    <Color x:Key="TextSecondaryColor">#64748B</Color>
    <Color x:Key="TextMutedColor">#94A3B8</Color>
    <Color x:Key="BorderColor">#CBD5E1</Color>
    <Color x:Key="BorderFocusColor">#2563EB</Color>

    <!-- ===== Sidebar ===== -->
    <Color x:Key="SidebarTextColor">#E2E8F0</Color>
    <Color x:Key="SidebarTextActiveColor">#FFFFFF</Color>
    <Color x:Key="SidebarItemHoverColor">#243656</Color>
    <Color x:Key="SidebarItemActiveColor">#2563EB</Color>

    <!-- ===== Status Colors ===== -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="NeutralColor">#94A3B8</Color>

    <!-- ===== Brushes (Primary Palette) ===== -->
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}" />

    <!-- ===== Sidebar Brushes ===== -->
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}" />
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="{StaticResource SidebarTextActiveColor}" />
    <SolidColorBrush x:Key="SidebarItemHoverBrush" Color="{StaticResource SidebarItemHoverColor}" />
    <SolidColorBrush x:Key="SidebarItemActiveBrush" Color="{StaticResource SidebarItemActiveColor}" />

    <!-- ===== Status Brushes ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralColor}" />

    <!-- Alias for primary text (same as TextBrush) -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextColor}" />

    <!-- ===== Campaign status pill brushes ===== -->
    <SolidColorBrush x:Key="StatusRunningBrush"   Color="#16A34A" />
    <SolidColorBrush x:Key="StatusPausedBrush"    Color="#D97706" />
    <SolidColorBrush x:Key="StatusCompletedBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="StatusScheduledBrush" Color="#704EE6" />
    <SolidColorBrush x:Key="StatusIdleBrush"      Color="#64748B" />

    <!-- ===== Overlay / Shadow ===== -->
    <Color x:Key="OverlayColor">#80000000</Color>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />

    <!-- ===== Info callout background ===== -->
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#EFF6FF" />

    <!-- ===== Selected data-grid row ===== -->
    <SolidColorBrush x:Key="SelectedRowBrush" Color="#DBEAFE" />

    <!-- ===== License status badge (BUG-058) ===== -->
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#DCFCE7" />

    <!-- ===== Log-level badges (BUG-045) ===== -->
    <SolidColorBrush x:Key="LogInfoBadgeBrush"    Color="#DBEAFE" />
    <SolidColorBrush x:Key="LogWarningBadgeBrush" Color="#FEF3C7" />
    <SolidColorBrush x:Key="LogErrorBadgeBrush"   Color="#FEE2E2" />

    <!-- ===== Button hover/pressed states (BUG-079) ===== -->
    <SolidColorBrush x:Key="SecondaryButtonHoverBrush"   Color="#0A2563EB" />
    <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#182563EB" />
    <SolidColorBrush x:Key="DangerButtonHoverBrush"      Color="#DC2626" />
    <SolidColorBrush x:Key="DangerButtonPressedBrush"    Color="#B91C1C" />

    <!-- ===== Sidebar divider (BUG-080) ===== -->
    <SolidColorBrush x:Key="SidebarDividerBrush" Color="#2D3E5A" />

    <!-- ===== Logo gradient (BUG-081) ===== -->
    <Color x:Key="LogoGradientStartColor">#2563EB</Color>
    <Color x:Key="LogoGradientEndColor">#1B2B4B</Color>

</ResourceDictionary>
