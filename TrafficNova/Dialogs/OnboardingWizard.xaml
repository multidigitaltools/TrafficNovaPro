<Window x:Class="TrafficNova.Dialogs.OnboardingWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/app.ico"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Welcome to TrafficNova Pro"
        Width="560" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="12" Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Step pages (only one visible at a time) -->

            <!-- Step 1: Welcome -->
            <StackPanel x:Name="Step1" Grid.Row="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Visible" Margin="48">
                <TextBlock Text="👋" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Welcome to TrafficNova Pro"
                           Style="{StaticResource HeadingLarge}"
                           HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="TrafficNova Pro automates web traffic using real browsers. It supports proxies, advanced scheduling, geo-spoofing, and stealth mode to simulate organic visitor behaviour."
                           Style="{StaticResource BodySecondary}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="400"/>
            </StackPanel>

            <!-- Step 2: Add proxies -->
            <StackPanel x:Name="Step2" Grid.Row="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed" Margin="48">
                <TextBlock Text="🔌" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Step 1 — Add Proxies"
                           Style="{StaticResource HeadingLarge}"
                           HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Go to the Proxies page and import your proxy list (IP:Port:User:Pass format, one per line). Proxies prevent IP bans and distribute traffic realistically."
                           Style="{StaticResource BodySecondary}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="400"/>
                <TextBlock Text="You can skip this step and add proxies later."
                           Style="{StaticResource BodySecondary}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="400" Margin="0,8,0,0" FontStyle="Italic"/>
            </StackPanel>

            <!-- Step 3: Create campaign -->
            <StackPanel x:Name="Step3" Grid.Row="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed" Margin="48">
                <TextBlock Text="🚀" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Step 2 — Create a Campaign"
                           Style="{StaticResource HeadingLarge}"
                           HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Go to the Campaigns page and click '＋ New Campaign'. Enter your target URLs, set thread count and visit target, choose a referrer mode, and click Save."
                           Style="{StaticResource BodySecondary}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="400"/>
            </StackPanel>

            <!-- Step 4: Ready! -->
            <StackPanel x:Name="Step4" Grid.Row="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed" Margin="48">
                <TextBlock Text="✅" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="You're Ready!"
                           Style="{StaticResource HeadingLarge}"
                           HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Click a campaign to select it, then press ▶ Start. Monitor live progress on the Dashboard. Check the Logs page if anything goes wrong."
                           Style="{StaticResource BodySecondary}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="400"/>
            </StackPanel>

            <!-- Bottom bar -->
            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Step indicator -->
                    <TextBlock x:Name="StepIndicator" Grid.Column="0"
                               VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>

                    <!-- Skip / Prev / Next buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="SkipButton" Content="Skip"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="OnSkip" Margin="0,0,8,0"/>
                        <Button x:Name="PrevButton" Content="← Back"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="OnPrev" Margin="0,0,8,0"
                                Visibility="Collapsed"/>
                        <Button x:Name="NextButton" Content="Next →"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnNext"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
