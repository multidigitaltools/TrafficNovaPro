<Window x:Class="TrafficNova.Dialogs.CampaignEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/app.ico"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="New Campaign"
        Width="640" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource BodySecondary}">
            <Setter Property="Margin" Value="0,12,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FormHint" TargetType="TextBlock" BasedOn="{StaticResource BodySecondary}">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>      <!-- Tabs -->
            <RowDefinition Height="Auto"/>   <!-- Validation msg -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="New Campaign"
                           Style="{StaticResource HeadingSmall}"/>
                <TextBlock x:Name="SubtitleText" Text="Configure campaign settings"
                           Style="{StaticResource BodySecondary}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab content -->
        <TabControl Grid.Row="1" Margin="20,12,20,0"
                    Background="Transparent" BorderThickness="0">

            <!-- ═══════════════ Tab 1: General ═══════════════ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>

                        <!-- Quick-start preset picker (only shown for new campaigns) -->
                        <Border Background="{DynamicResource InfoBackgroundBrush}" CornerRadius="6" Padding="10,8"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsNewCampaign, Converter={StaticResource BoolToVisibleConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Quick-start from preset:"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource BodySecondary}"
                                           Margin="0,0,8,0"/>
                                <ComboBox x:Name="PresetCombo"
                                          ItemsSource="{Binding PresetNames}"
                                          SelectedIndex="0"
                                          Width="220" Margin="0,0,8,0"
                                          SelectionChanged="PresetCombo_SelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Campaign Name" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="NameBox" Text="{Binding CampaignName, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="120" hc:InfoElement.Placeholder="e.g. Blog Traffic - May 2026"/>

                        <TextBlock Text="Target URLs (one per line)" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="UrlsBox"
                                 Text="{Binding TargetUrlsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="100" VerticalScrollBarVisibility="Auto"
                                 hc:InfoElement.Placeholder="https://example.com/page1&#x0a;https://example.com/page2"
                                 FontFamily="Consolas" FontSize="12"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Thread Count" Style="{StaticResource FormLabel}"/>
                                    <TextBlock Text="?" Style="{StaticResource HelpLabel}"
                                               ToolTip="Number of parallel browser sessions. Higher = faster but uses more RAM and CPU. Recommend ≤10 on most machines."/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="ThreadSlider"
                                            Minimum="1" Maximum="50" TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding ThreadCount}"
                                            VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Margin="8,0,0,0"
                                             Text="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}"
                                             TextAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Visit Target (0 = unlimited)" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding VisitTarget, UpdateSourceTrigger=PropertyChanged}"
                                         TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Step 103: warm-up visits -->
                        <TextBlock Text="Warm-up Visits (0 = none)" Style="{StaticResource FormLabel}" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding WarmupVisits, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="Visits to domain root before main campaign URL (shares cookie jar)."
                                   Style="{StaticResource FormHint}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ Tab 2: Traffic ═══════════════ -->
            <TabItem Header="Traffic">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Dwell Time — Min (seconds)" Style="{StaticResource FormLabel}"/>
                            <TextBlock Text="?" Style="{StaticResource HelpLabel}"
                                       ToolTip="Minimum time the browser stays on the page (seconds). Simulates real reading behaviour. Random value between Min and Max is chosen per visit."/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="1" Maximum="300" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding DwellMinSec}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Margin="8,0,0,0"
                                     Text="{Binding DwellMinSec, UpdateSourceTrigger=PropertyChanged}"
                                     TextAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Dwell Time — Max (seconds)" Style="{StaticResource FormLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="1" Maximum="600" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding DwellMaxSec}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Margin="8,0,0,0"
                                     Text="{Binding DwellMaxSec, UpdateSourceTrigger=PropertyChanged}"
                                     TextAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Bounce Rate (0 = always scroll, 1 = always bounce)"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBlock Text="?" Style="{StaticResource HelpLabel}"
                                       ToolTip="Probability that a visitor leaves immediately without scrolling. 0 = all visitors scroll. 0.5 = half bounce. Matches your site's real analytics ratio."/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="1" TickFrequency="0.05"
                                    Value="{Binding BounceRate}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Margin="8,0,0,0"
                                     Text="{Binding BounceRateDisplay, Mode=OneWay}"
                                     IsReadOnly="True" TextAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Referrer Mode" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding ReferrerModes}"
                                  SelectedItem="{Binding SelectedReferrerMode}"
                                  SelectionChanged="ConditionalCombo_SelectionChanged"/>

                        <TextBlock x:Name="CustomReferrerLabel" Text="Custom Referrer URL" Style="{StaticResource FormLabel}"
                                   Visibility="{Binding IsCustomReferrer, Converter={StaticResource BoolToVisibleConverter}}"/>
                        <TextBox x:Name="CustomReferrerBox" Text="{Binding CustomReferrer, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsCustomReferrer, Converter={StaticResource BoolToVisibleConverter}}"
                                 hc:InfoElement.Placeholder="https://google.com/search?q=keyword"/>

                        <!-- Step 98: keywords for Google/Bing referrer variation -->
                        <TextBlock x:Name="SearchKeywordsLabel" Text="Search Keywords (comma-separated)" Style="{StaticResource FormLabel}"
                                   Visibility="{Binding IsSearchReferrer, Converter={StaticResource BoolToVisibleConverter}}"/>
                        <TextBox x:Name="SearchKeywordsBox" Text="{Binding ReferrerKeywords, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsSearchReferrer, Converter={StaticResource BoolToVisibleConverter}}"
                                 hc:InfoElement.Placeholder="buy shoes online, best sneakers 2024, ..."/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ Tab 3: Browser ═══════════════ -->
            <TabItem Header="Browser">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>

                        <TextBlock Text="User Agent Mode" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding UserAgentModes}"
                                  SelectedItem="{Binding SelectedUserAgentMode}"
                                  SelectionChanged="ConditionalCombo_SelectionChanged"/>

                        <TextBlock x:Name="CustomUaLabel" Text="Custom User Agent String" Style="{StaticResource FormLabel}"
                                   Visibility="{Binding IsCustomUA, Converter={StaticResource BoolToVisibleConverter}}"/>
                        <TextBox x:Name="CustomUaBox" Text="{Binding CustomUserAgent, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsCustomUA, Converter={StaticResource BoolToVisibleConverter}}"
                                 hc:InfoElement.Placeholder="Mozilla/5.0 (Windows NT 10.0; Win64; x64)..."
                                 TextWrapping="Wrap" Height="60"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Window Size" Style="{StaticResource FormLabel}"/>
                                <ComboBox ItemsSource="{Binding WindowSizes}"
                                          SelectedItem="{Binding WindowSize}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Browser Language" Style="{StaticResource FormLabel}"/>
                                <ComboBox ItemsSource="{Binding Languages}"
                                          SelectedItem="{Binding BrowserLanguage}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Timezone" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding Timezones}"
                                  SelectedItem="{Binding Timezone}"/>

                        <CheckBox Content="JavaScript enabled" Margin="0,12,0,4"
                                  IsChecked="{Binding JavaScriptEnabled}"/>
                        <CheckBox Content="Accept cookies" Margin="0,4,0,4"
                                  IsChecked="{Binding AcceptCookies}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <TextBlock Text="Resource Blocking" Style="{StaticResource FormLabel}" Margin="0,0,0,0"/>
                            <TextBlock Text="?" Style="{StaticResource HelpLabel}"
                                       ToolTip="Abort heavy sub-resources to cut bandwidth/proxy cost and run much faster.&#x0a;None: load everything.&#x0a;Media: block images, video/audio and fonts.&#x0a;Aggressive: also block stylesheets and analytics/tracking beacons."/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding ResourceBlockModes}"
                                  SelectedItem="{Binding ResourceBlockMode}"/>
                        <TextBlock Style="{StaticResource FormHint}"
                                   Text="Aggressive mode can break sites that lazy-load content via CSS; use Media for the best balance."/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ Tab 4: Proxy ═══════════════ -->
            <TabItem Header="Proxy">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>

                        <CheckBox Content="Use proxy for this campaign" Margin="0,8,0,12"
                                  FontWeight="SemiBold"
                                  IsChecked="{Binding UseProxy}"/>

                        <StackPanel IsEnabled="{Binding UseProxy}">

                            <TextBlock Text="Proxy Group (blank = all active proxies)"
                                       Style="{StaticResource FormLabel}"/>
                            <ComboBox ItemsSource="{Binding ProxyGroups}"
                                      SelectedItem="{Binding ProxyGroupTag}"
                                      IsEditable="True"
                                      hc:InfoElement.Placeholder="Leave blank for all proxies"/>

                            <TextBlock Text="Rotation Strategy" Style="{StaticResource FormLabel}"/>
                            <ComboBox ItemsSource="{Binding RotationStrategies}"
                                      SelectedItem="{Binding SelectedRotationStrategy}"/>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════ Tab 5: Advanced (Step 97, 99) ═══════════════ -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                    <StackPanel>

                        <!-- Geo-spoof (Step 97) -->
                        <TextBlock Text="Geo-Spoof Country" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding GeoCountries}"
                                  SelectedItem="{Binding GeoCountry}"
                                  Width="200" HorizontalAlignment="Left"/>
                        <TextBlock Text="Overrides locale and timezone to match the selected country. Leave blank for campaign defaults."
                                   Style="{StaticResource FormHint}"/>

                        <!-- Custom HTTP headers (Step 99) -->
                        <TextBlock Text="Custom HTTP Headers" Style="{StaticResource FormLabel}"
                                   Margin="0,16,0,4"/>
                        <TextBlock Style="{StaticResource FormHint}"
                                   Text="One header per line in Name: Value format. Content-Length and Host cannot be overridden."
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="CustomHeadersBox"
                                 Text="{Binding CustomHeadersText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 MinHeight="100"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 hc:InfoElement.Placeholder="X-Custom-Header: value&#xA;Accept-Language: en-US"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Validation message -->
        <TextBlock x:Name="ValidationMsg" Grid.Row="2"
                   Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                   Margin="20,6,20,0" TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Action buttons -->
        <Border Grid.Row="3" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Button x:Name="TestRunButton" Content="▶  Test Run (1 visit)"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Left" Width="160"
                        Click="TestRun_Click"
                        ToolTip="Run a single real visit with the current settings and show the result before launching the full campaign."/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                            Width="90" Click="Cancel_Click" Margin="0,0,8,0"/>
                    <Button x:Name="SaveCampaignBtn" Content="Save Campaign"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="130" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
