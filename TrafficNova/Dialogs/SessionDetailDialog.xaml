<Window x:Class="TrafficNova.Dialogs.SessionDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/app.ico"
        Title="Session Detail"
        Width="560" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="K" TargetType="TextBlock" BasedOn="{StaticResource BodySecondary}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,12,0"/>
        </Style>
        <Style x:Key="V" TargetType="TextBlock" BasedOn="{StaticResource BaseTextStyle}">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Session Detail"
                           Style="{StaticResource HeadingSmall}"/>
                <TextBlock x:Name="SubtitleText" Style="{StaticResource BodySecondary}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,8,20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Result" Style="{StaticResource K}"/>
                <TextBlock x:Name="ResultText" Grid.Row="0" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Target URL" Style="{StaticResource K}"/>
                <TextBlock x:Name="UrlText" Grid.Row="1" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="HTTP Status" Style="{StaticResource K}"/>
                <TextBlock x:Name="StatusText" Grid.Row="2" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Started" Style="{StaticResource K}"/>
                <TextBlock x:Name="StartedText" Grid.Row="3" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Duration" Style="{StaticResource K}"/>
                <TextBlock x:Name="DurationText" Grid.Row="4" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Dwell" Style="{StaticResource K}"/>
                <TextBlock x:Name="DwellText" Grid.Row="5" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Blocked Requests" Style="{StaticResource K}"/>
                <TextBlock x:Name="BlockedText" Grid.Row="6" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Proxy ID" Style="{StaticResource K}"/>
                <TextBlock x:Name="ProxyText" Grid.Row="7" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="User-Agent" Style="{StaticResource K}"/>
                <TextBlock x:Name="UaText" Grid.Row="8" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Referrer" Style="{StaticResource K}"/>
                <TextBlock x:Name="ReferrerText" Grid.Row="9" Grid.Column="1" Style="{StaticResource V}"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Error" Style="{StaticResource K}"/>
                <TextBlock x:Name="ErrorText" Grid.Row="10" Grid.Column="1" Style="{StaticResource V}"
                           Foreground="{DynamicResource ErrorBrush}"/>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OpenScreenshotBtn" Content="🖼  Open Screenshot"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="160" Margin="0,0,8,0" Click="OpenScreenshot_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="OpenTraceBtn" Content="📁  Open Trace Folder"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="170" Margin="0,0,8,0" Click="OpenTrace_Click"
                        Visibility="Collapsed"/>
                <Button Content="Close" Style="{StaticResource PrimaryButtonStyle}"
                        Width="90" Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
