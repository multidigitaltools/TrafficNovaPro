<Window x:Class="TrafficNova.Dialogs.ProxyEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/app.ico"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Proxy Editor"
        Width="440" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="TitleText" Text="Add Proxy"
                   Style="{StaticResource HeadingSmall}" Margin="0,0,0,20"/>

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>

                <!-- Protocol -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Protocol *" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ProtocolBox"
                              ItemsSource="{Binding ProtocolOptions}"
                              SelectedItem="{Binding Protocol}"/>
                </Grid>

                <!-- Host -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Host *" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <TextBox Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                             hc:InfoElement.Placeholder="e.g. 192.168.1.1 or proxy.example.com"/>
                </Grid>

                <!-- Port -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Port *" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <hc:NumericUpDown Grid.Column="1" Value="{Binding Port}"
                                      Minimum="1" Maximum="65535"/>
                </Grid>

                <!-- Username -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Username" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <TextBox Grid.Column="1" Text="{Binding Username}"
                             hc:InfoElement.Placeholder="optional"/>
                </Grid>

                <!-- Password -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Password" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <PasswordBox Grid.Column="1" x:Name="PasswordField"
                                 hc:InfoElement.Placeholder="optional"
                                 PasswordChanged="PasswordField_Changed"/>
                </Grid>

                <!-- Label -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Label" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <TextBox Grid.Column="1" Text="{Binding Label}"
                             hc:InfoElement.Placeholder="optional friendly name"/>
                </Grid>

                <!-- Group -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Group" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}"/>
                    <TextBox Grid.Column="1" Text="{Binding GroupTag}"
                             hc:InfoElement.Placeholder="optional group tag"/>
                </Grid>

                <!-- Step 102: chain proxy stub -->
                <Separator Margin="0,8"/>
                <StackPanel Margin="0,0,0,8">
                    <CheckBox Content="Enable proxy chain (v1 stub)"
                              IsChecked="{Binding UseChain}"
                              FontSize="13" Cursor="Hand"/>
                    <TextBlock Text="⚠ Reserved for future upstream SOCKS5 chain support. Has no effect in v1."
                               TextWrapping="Wrap" FontSize="11"
                               Foreground="{DynamicResource WarningBrush}"
                               Margin="20,4,0,0"/>
                </StackPanel>

                <!-- Validation message -->
                <TextBlock x:Name="ValidationMsg" Foreground="{DynamicResource ErrorBrush}"
                           FontSize="{StaticResource FontSizeSM}" Margin="0,12,0,0"
                           Visibility="Collapsed"/>

            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                    Width="90" Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                    Width="90" Click="Save_Click"/>
        </StackPanel>

    </Grid>
</Window>
