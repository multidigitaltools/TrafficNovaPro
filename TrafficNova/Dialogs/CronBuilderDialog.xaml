<Window x:Class="TrafficNova.Dialogs.CronBuilderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/app.ico"
        Title="Schedule Job" Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="PresetBtnStyle" TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{Binding WindowTitle}"
                   Style="{StaticResource HeadingMedium}"
                   Margin="0,0,0,20"/>

        <!-- Campaign picker -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Campaign" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
            <ComboBox x:Name="CampaignCombo"
                      ItemsSource="{Binding Campaigns}"
                      SelectedItem="{Binding SelectedCampaign, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Width="460" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Cron presets -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Quick Presets" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
            <WrapPanel>
                <Button Content="Every Hour"   Style="{StaticResource PresetBtnStyle}" Tag="0 * * * *"    Click="OnPreset"/>
                <Button Content="Every 4 h"    Style="{StaticResource PresetBtnStyle}" Tag="0 */4 * * *"  Click="OnPreset"/>
                <Button Content="Every 6 h"    Style="{StaticResource PresetBtnStyle}" Tag="0 */6 * * *"  Click="OnPreset"/>
                <Button Content="Daily 9 AM"   Style="{StaticResource PresetBtnStyle}" Tag="0 9 * * *"    Click="OnPreset"/>
                <Button Content="Daily 12 PM"  Style="{StaticResource PresetBtnStyle}" Tag="0 12 * * *"   Click="OnPreset"/>
                <Button Content="Daily 9 PM"   Style="{StaticResource PresetBtnStyle}" Tag="0 21 * * *"   Click="OnPreset"/>
                <Button Content="Mon–Fri 9 AM" Style="{StaticResource PresetBtnStyle}" Tag="0 9 * * 1-5"  Click="OnPreset"/>
                <Button Content="Weekly Mon"   Style="{StaticResource PresetBtnStyle}" Tag="0 9 * * 1"    Click="OnPreset"/>
                <Button Content="Twice Daily"  Style="{StaticResource PresetBtnStyle}" Tag="0 9,21 * * *" Click="OnPreset"/>
            </WrapPanel>
        </StackPanel>

        <!-- Manual cron input -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Cron Expression (5-field: min h dom mon dow)"
                       FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CronBox"
                         Grid.Column="0"
                         Text="{Binding CronExpression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="13"
                         Padding="10,8"
                         TextChanged="OnCronChanged"/>
                <Button Grid.Column="1" Content="Validate"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="8,0,0,0" Padding="12,8"
                        Click="OnValidate"/>
            </Grid>
        </StackPanel>

        <!-- Next-runs preview -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Next 5 occurrences:" FontWeight="SemiBold"
                       FontSize="12" Margin="0,0,0,6"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
            <Border Style="{StaticResource CardStyle}" Padding="14,10">
                <TextBlock x:Name="NextRunsBlock"
                           Text="{Binding NextRunsText}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{DynamicResource TextBrush}"
                           LineHeight="20"/>
            </Border>

            <!-- Validation message -->
            <TextBlock x:Name="ValidationMsg"
                       Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource ErrorBrush}"
                       FontSize="12" Margin="0,8,0,0"
                       Visibility="{Binding ValidationMessage,
                           Converter={StaticResource StringNonEmptyToVisibleConverter}}"/>
        </StackPanel>

        <!-- Action buttons -->
        <Border Grid.Row="5" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,9" Margin="0,0,10,0"
                        Click="OnCancel"/>
                <Button Content="Save Schedule" IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,9"
                        Click="OnSave"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
