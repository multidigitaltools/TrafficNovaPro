<UserControl x:Class="TrafficNova.Pages.CampaignsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TrafficNova.ViewModels"
             xmlns:models="clr-namespace:TrafficNova.Core.Models;assembly=TrafficNova.Core"
             xmlns:local="clr-namespace:TrafficNova.Pages"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Summary cards -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Campaigns" Style="{StaticResource HeadingLarge}"/>
                    <TextBlock Text="Manage and monitor all traffic campaigns"
                               Style="{StaticResource BodySecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="＋  New Campaign"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnNewCampaign"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Summary cards ── -->
        <ItemsControl Grid.Row="1" Margin="24,16,24,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" Columns="4" HorizontalAlignment="Stretch"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Total -->
            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Campaigns" Style="{StaticResource BodySecondary}"/>
                </StackPanel>
            </Border>

            <!-- Running -->
            <Border Style="{StaticResource StatCardStyle}" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="RUNNING" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding RunningCount}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource StatusRunningBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Active now" Style="{StaticResource BodySecondary}"/>
                </StackPanel>
            </Border>

            <!-- Paused -->
            <Border Style="{StaticResource StatCardStyle}" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="PAUSED" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding PausedCount}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource StatusPausedBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="On hold" Style="{StaticResource BodySecondary}"/>
                </StackPanel>
            </Border>

            <!-- Completed -->
            <Border Style="{StaticResource StatCardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="COMPLETED" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource StatusCompletedBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Finished" Style="{StaticResource BodySecondary}"/>
                </StackPanel>
            </Border>
        </ItemsControl>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Margin="0,16,0,0" Padding="16,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="▶  Start"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding StartCommand}"
                        ToolTip="Start selected campaign"/>
                <Button Content="⏹  Stop"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding StopCommand}"
                        ToolTip="Stop selected campaign"/>
                <Button Content="⏸  Pause / Resume"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding PauseCommand}"
                        ToolTip="Pause or resume selected campaign"/>
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                <Button Content="✎  Edit"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="OnEditCampaign"
                        ToolTip="Edit selected campaign"/>
                <Button Content="⧉  Duplicate"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding DuplicateCommand}"
                        ToolTip="Duplicate selected campaign"/>
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                <Button Content="🗑  Delete"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding DeleteCommand}"
                        ToolTip="Delete selected campaign"/>
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                <Button Content="↺  Refresh"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding LoadCommand}"
                        ToolTip="Refresh campaign list"/>
                <Separator Width="1" Background="{DynamicResource BorderBrush}" Margin="8,0"/>
                <Button Content="⬆  Export"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ExportCampaignsCommand}"
                        ToolTip="Export all campaigns to JSON"/>
                <Button Content="⬇  Import"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ImportCampaignsCommand}"
                        ToolTip="Import campaigns from JSON"/>
            </StackPanel>
        </Border>

        <!-- ── Filter + bulk actions bar ── -->
        <Border Grid.Row="3" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filter:" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding FilterStatus}"
                              Width="130"/>
                </StackPanel>
                <!-- Bulk action buttons (Step 108) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Bulk:" VerticalAlignment="Center"
                               Style="{StaticResource BodySecondary}" Margin="0,0,8,0"/>
                    <Button Content="▶  Start All"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding BulkStartCommand}"
                            ToolTip="Start all (or selected) campaigns" Margin="0,0,4,0"/>
                    <Button Content="⏹  Stop All"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding BulkStopCommand}"
                            ToolTip="Stop all (or selected) running campaigns" Margin="0,0,4,0"/>
                    <Button Content="🗑  Delete All"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding BulkDeleteCommand}"
                            ToolTip="Delete all (or selected) campaigns"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Grid Grid.Row="4" Margin="24,16,24,24">
            <!-- Loading overlay (Step 111) -->
            <Border Background="{DynamicResource OverlayBrush}" Panel.ZIndex="10"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibleConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <hc:LoadingCircle Width="40" Height="40"/>
                    <TextBlock Text="Loading…" Style="{StaticResource BodySecondary}"
                               Foreground="White"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="No campaigns yet" Style="{StaticResource HeadingSmall}"
                           HorizontalAlignment="Center" Margin="0,8,0,4"/>
                <TextBlock Text="Click '＋ New Campaign' to create your first campaign."
                           Style="{StaticResource BodySecondary}" HorizontalAlignment="Center"/>
            </StackPanel>

            <DataGrid x:Name="CampaignGrid"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding Selected}"
                      SelectionMode="Extended"
                      MouseDoubleClick="OnGridDoubleClick"
                      VirtualizingPanel.IsVirtualizing="True"
                      Visibility="{Binding Items.Count, Converter={StaticResource NonZeroToVisibleConverter}}">
                <DataGrid.Columns>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Status" Width="100" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Status, Converter={StaticResource StatusToBackgroundConverter}}">
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToForegroundConverter}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Name -->
                    <DataGridTextColumn Header="Name" Width="*"
                                        Binding="{Binding Name}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <!-- URL count -->
                    <DataGridTemplateColumn Header="URLs" Width="70" SortMemberPath="TargetUrlsJson">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TargetUrlsJson, Converter={StaticResource JsonToUrlCountConverter}}"
                                           Style="{StaticResource DataGridCellTextStyle}"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Threads -->
                    <DataGridTextColumn Header="Threads" Width="80"
                                        Binding="{Binding ThreadCount}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <!-- Visit target -->
                    <DataGridTextColumn Header="Target" Width="80"
                                        Binding="{Binding VisitTarget}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <!-- Live progress (Phase 10) -->
                    <DataGridTemplateColumn Header="Progress" Width="150" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center" Margin="2,0">
                                    <ProgressBar Height="16" Minimum="0" Maximum="100">
                                        <ProgressBar.Value>
                                            <MultiBinding Converter="{StaticResource ProgressPercentConverter}">
                                                <Binding Path="TotalVisits"/>
                                                <Binding Path="VisitTarget"/>
                                            </MultiBinding>
                                        </ProgressBar.Value>
                                    </ProgressBar>
                                    <TextBlock FontSize="10" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource ProgressTextConverter}">
                                                <Binding Path="TotalVisits"/>
                                                <Binding Path="VisitTarget"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Last run -->
                    <DataGridTextColumn Header="Last Run" Width="150"
                                        Binding="{Binding LastRunAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}', TargetNullValue='—'}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <!-- Created -->
                    <DataGridTextColumn Header="Created" Width="120"
                                        Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}'}"
                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <!-- Quick-action buttons -->
                    <DataGridTemplateColumn Header="" Width="120" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="▶"
                                            ToolTip="Start"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Padding="6,2"
                                            FontSize="11"
                                            Command="{Binding DataContext.StartCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="⏹"
                                            ToolTip="Stop"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Padding="6,2"
                                            FontSize="11"
                                            Command="{Binding DataContext.StopCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

                <!-- Context menu -->
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="▶  Start"
                                  Command="{Binding PlacementTarget.DataContext.StartCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="⏹  Stop"
                                  Command="{Binding PlacementTarget.DataContext.StopCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="⏸  Pause / Resume"
                                  Command="{Binding PlacementTarget.DataContext.PauseCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="✎  Edit" Click="OnEditCampaign"/>
                        <MenuItem Header="⧉  Duplicate"
                                  Command="{Binding PlacementTarget.DataContext.DuplicateCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="🗑  Delete"
                                  Command="{Binding PlacementTarget.DataContext.DeleteCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <!-- History panel — shown when a campaign is selected (via code-behind) -->
            <local:CampaignHistoryPanel x:Name="HistoryPanel"
                                        Grid.Row="0"
                                        Visibility="Collapsed"
                                        VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</UserControl>
