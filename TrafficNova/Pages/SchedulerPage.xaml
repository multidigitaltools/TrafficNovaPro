<UserControl x:Class="TrafficNova.Pages.SchedulerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TrafficNova.ViewModels"
             xmlns:local="clr-namespace:TrafficNova.Pages"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="28,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Scheduler" Style="{StaticResource HeadingLarge}"/>
                    <TextBlock Text="Automate campaign execution with cron schedules."
                               Style="{StaticResource BodySecondary}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Add Schedule"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,9" VerticalAlignment="Center"
                        Click="OnAddJob"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Edit"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,7" Margin="0,0,6,0"
                        Click="OnEditJob"/>
                <Button Content="Delete"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,7" Margin="0,0,6,0"
                        Command="{Binding DeleteJobCommand}"
                        CommandParameter="{Binding SelectedJob}"/>
                <Button Content="Run Now"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,7" Margin="0,0,6,0"
                        Command="{Binding RunNowCommand}"
                        CommandParameter="{Binding SelectedJob}"/>
                <Separator Width="1" Height="22" Margin="6,0"/>
                <Button Content="Refresh"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,7"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </Border>

        <!-- Jobs grid -->
        <Grid Grid.Row="2" Margin="24">
            <!-- Empty state -->
            <Border Style="{StaticResource CardStyle}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="40,32"
                    Visibility="{Binding Jobs.Count,
                        Converter={StaticResource ZeroToVisibleConverter}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="No scheduled jobs"
                               Style="{StaticResource HeadingSmall}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Click '+ Add Schedule' to automate a campaign."
                               Style="{StaticResource BodySecondary}"
                               HorizontalAlignment="Center" Margin="0,6,0,16"/>
                    <Button Content="+ Add Schedule"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Center" Padding="16,9"
                            Click="OnAddJob"/>
                </StackPanel>
            </Border>

            <!-- Data grid -->
            <Border Style="{StaticResource CardStyle}"
                    Padding="0"
                    Visibility="{Binding Jobs.Count,
                        Converter={StaticResource NonZeroToVisibleConverter}}">
                <DataGrid x:Name="JobGrid"
                          ItemsSource="{Binding Jobs}"
                          SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          Background="{DynamicResource CardBrush}"
                          BorderThickness="0"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <!-- Enabled toggle -->
                        <DataGridTemplateColumn Header="Enabled" Width="72">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Cursor="Hand"
                                              Command="{Binding DataContext.ToggleEnabledCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Campaign name -->
                        <DataGridTextColumn Header="Campaign" Width="*"
                                            Binding="{Binding Campaign.Name, TargetNullValue='(no campaign)'}"/>

                        <!-- Cron expression -->
                        <DataGridTextColumn Header="Schedule (Cron)" Width="160"
                                            Binding="{Binding CronExpression}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,6"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Next run -->
                        <DataGridTextColumn Header="Next Run" Width="160"
                                            Binding="{Binding NextRunAt, StringFormat='yyyy-MM-dd HH:mm',
                                                TargetNullValue='—'}"/>

                        <!-- Last run -->
                        <DataGridTextColumn Header="Last Run" Width="160"
                                            Binding="{Binding LastRunAt, StringFormat='yyyy-MM-dd HH:mm',
                                                TargetNullValue='—'}"/>

                        <!-- Run count -->
                        <DataGridTextColumn Header="Runs" Width="60"
                                            Binding="{Binding RunCount}"/>

                        <!-- Max runs -->
                        <DataGridTextColumn Header="Max" Width="60"
                                            Binding="{Binding MaxRuns, Converter={StaticResource MaxRunsConverter}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="12,6"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="8,4">
                                        <Button Content="Run Now"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                                Command="{Binding DataContext.RunNowCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" FontSize="11"
                                                Command="{Binding DataContext.DeleteJobCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Run history panel (shown when a job is selected) -->
        <local:CampaignHistoryPanel x:Name="HistoryPanel"
                                    Grid.Row="3"
                                    Visibility="Collapsed"/>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource BodySecondary}"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</UserControl>
