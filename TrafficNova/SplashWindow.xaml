<Window x:Class="TrafficNova.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrafficNova Pro"
        Width="420" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">

    <Border Background="{DynamicResource SidebarBrush}"
            CornerRadius="12"
            BorderBrush="#2D3E5A"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Logo area -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,32,0,0">
                <Ellipse Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#2563EB" Offset="0"/>
                            <GradientStop Color="#1B2B4B" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock Text="TrafficNova Pro"
                           Foreground="White"
                           FontSize="{StaticResource FontSize2XL}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Professional Web Traffic Bot"
                           Foreground="#94A3B8"
                           FontSize="{StaticResource FontSizeSM}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Status message -->
            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Text="Initializing…"
                       Foreground="#64748B"
                       FontSize="{StaticResource FontSizeSM}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,8"/>

            <!-- Progress bar -->
            <ProgressBar x:Name="ProgressBar"
                         Grid.Row="2"
                         IsIndeterminate="True"
                         Height="3"
                         Margin="40,0"
                         Background="#2D3E5A"
                         Foreground="{DynamicResource PrimaryBrush}"/>

            <!-- Version -->
            <TextBlock Grid.Row="3"
                       Text="v1.0.0"
                       Foreground="#475569"
                       FontSize="{StaticResource FontSizeXS}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

        </Grid>
    </Border>
</Window>
