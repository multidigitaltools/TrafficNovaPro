<Window x:Class="TrafficNova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:TrafficNova.ViewModels"
        Title="TrafficNova Pro"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False">

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"/>
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Campaigns"/>
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Proxies"/>
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Scheduler"/>
        <KeyBinding Key="D5" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
        <KeyBinding Key="D6" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Logs"/>
        <KeyBinding Key="OemComma" Modifiers="Ctrl" Command="{Binding NavigateToCommand}" CommandParameter="Settings"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ======= Custom Title Bar ======= -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource SidebarBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + App Name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="24" Height="24" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="TrafficNova Pro"
                               Foreground="White" FontWeight="Bold"
                               FontSize="{StaticResource FontSizeMD}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Title (current page) -->
                <TextBlock Grid.Column="1"
                           Text="{Binding ActivePageName}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSM}"
                           VerticalAlignment="Center"
                           Margin="12,0"/>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Content="─" Foreground="White" Background="Transparent"
                            BorderThickness="0" Width="40" Height="32"
                            Cursor="Hand" Click="Minimize_Click"
                            FontSize="16" VerticalContentAlignment="Bottom"/>
                    <Button x:Name="MaxRestoreBtn" Content="□" Foreground="White" Background="Transparent"
                            BorderThickness="0" Width="40" Height="32"
                            Cursor="Hand" Click="MaxRestore_Click" FontSize="13"/>
                    <Button Content="✕" Foreground="White" Background="Transparent"
                            BorderThickness="0" Width="40" Height="32"
                            Cursor="Hand" Click="Close_Click" FontSize="13">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerButtonHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======= Sidebar ======= -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource SidebarBrush}">
            <DockPanel>

                <!-- Nav Items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                            ToolTip="Dashboard (Ctrl+1)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Campaigns"
                            ToolTip="Campaigns (Ctrl+2)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="14" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Campaigns" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Proxies"
                            ToolTip="Proxies (Ctrl+3)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⇄" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Proxies" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Scheduler"
                            ToolTip="Scheduler (Ctrl+4)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏰" FontSize="14" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Scheduler" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="{DynamicResource SidebarDividerBrush}" Margin="16,8"/>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Logs"
                            ToolTip="Logs (Ctrl+6)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☰" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Logs" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Bottom: Settings + About -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Settings"
                            ToolTip="Settings (Ctrl+,)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Command="{Binding NavigateToCommand}" CommandParameter="About"
                            ToolTip="About">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ" FontSize="16" Margin="0,0,10,0"
                                       Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="About" Foreground="{DynamicResource SidebarTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ======= Content Area ======= -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                         Content="{Binding CurrentPage}"
                         Background="{DynamicResource BackgroundBrush}"/>

        <!-- ======= Status Bar ======= -->
        <Border Grid.Row="2" Grid.ColumnSpan="2"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Style="{StaticResource BodyMuted}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Margin="0,0,16,0"
                           Style="{StaticResource BodyMuted}"
                           VerticalAlignment="Center">
                    <Run Text="Sessions: "/>
                    <Run Text="{Binding ActiveSessions}"/>
                </TextBlock>
                <TextBlock Grid.Column="2"
                           Text="v1.0.0"
                           Style="{StaticResource BodyMuted}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
